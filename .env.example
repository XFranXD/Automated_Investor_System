# MongoDB Atlas Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/tbe?retryWrites=true&w=majority

# Finnhub API Key (Free tier)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Twelve Data API Key (Free tier)
TWELVEDATA_API_KEY=your_twelvedata_api_key_here

# SEC EDGAR User Agent (Required contact info for SEC rate limits)
# Format: CompanyName/AppName contact@domain.com
SEC_EDGAR_USER_AGENT=Ale contact@domain.com

# Gemini API Keys (Three keys from separate GC projects for rotation)
GEMINI_API_KEY_1=your_gemini_api_key_1_here
GEMINI_API_KEY_2=your_gemini_api_key_2_here
GEMINI_API_KEY_3=your_gemini_api_key_3_here
# Email Notifications (Secure Gmail SMTP)
EMAIL_SENDER=sender_gmail_address@gmail.com
EMAIL_RECEIVER=receiver_gmail_address@gmail.com
EMAIL_APP_PASSWORD=your_gmail_16_char_app_password_here
